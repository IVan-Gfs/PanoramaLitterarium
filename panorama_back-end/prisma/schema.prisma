generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model AnaliseAvaliacao {
  id            BigInt                    @id @default(autoincrement())
  anotacaoGeral String?
  fase          Int
  status        AnaliseAvaliacaoStatus   @default(PENDENTE)
  submissaoId   BigInt
  bancaId       BigInt
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  banca         Banca                    @relation(fields: [bancaId], references: [id], map: "AnaliseAvaliacao_bancaId_fkey")
  submissao     Submissao                @relation(fields: [submissaoId], references: [id], map: "AnaliseAvaliacao_submissaoId_fkey")
  anotacao      Anotacao[]
  nota          Nota[]

  @@unique([submissaoId, bancaId, fase], map: "AnaliseAvaliacao_submissaoId_bancaId_fase_key")
  @@index([bancaId], map: "AnaliseAvaliacao_bancaId_fkey")
}

model Anotacao {
  id               BigInt            @id @default(autoincrement())
  texto            String
  inicio           Int
  fim              Int
  analiseId        BigInt
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analiseavaliacao AnaliseAvaliacao  @relation(fields: [analiseId], references: [id], map: "Anotacao_analiseId_fkey")

  @@index([analiseId], map: "Anotacao_analiseId_fkey")
}

model Banca {
  id               BigInt              @id @default(autoincrement())
  juradoId         BigInt
  concursoId       BigInt
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  analiseavaliacao AnaliseAvaliacao[]
  concurso         Concurso            @relation(fields: [concursoId], references: [id], map: "Banca_concursoId_fkey")
  jurado           Jurado              @relation(fields: [juradoId], references: [id], map: "Banca_juradoId_fkey")

  @@unique([juradoId, concursoId], map: "Banca_juradoId_concursoId_key")
  @@index([concursoId], map: "Banca_concursoId_fkey")
}

model Concurso {
  id              BigInt        @id @default(autoincrement())
  titulo          String?
  imgCapa         String?
  generoLiterario String?       @default("DIVERSOS")
  qtdVencedores   Int?
  taxaInscricao   Decimal?
  tema            String?       @default("LIVRE")
  municipio       String?
  uf              String?       @db.Char(2)
  premiacao       String?
  prazoInscricao  DateTime?
  limiteObras     Int?          @default(1)
  restricao       String?       @default("NENHUMA")
  etapaAtual      Int?          @default(1)
  linkEdital      String?
  pdfEdital       String?
  dataFinalizacao DateTime?
  organizacaoId   BigInt
  grupoCriterioId BigInt
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  descricao       String?
  banca           Banca[]
  grupoCriterio   GrupoCriterio @relation(fields: [grupoCriterioId], references: [id], map: "Concurso_grupoCriterioId_fkey")
  organizacao     Organizacao   @relation(fields: [organizacaoId], references: [id], map: "Concurso_organizacaoId_fkey")
  inscricao       Inscricao[]

  @@index([grupoCriterioId], map: "Concurso_grupoCriterioId_fkey")
  @@index([organizacaoId], map: "Concurso_organizacaoId_fkey")
}

model Criterio {
  id              BigInt        @id @default(autoincrement())
  nome            String?
  descricao       String?
  pontuacaoMax    Float?
  grupoCriterioId BigInt
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  grupoCriterio   GrupoCriterio @relation(fields: [grupoCriterioId], references: [id], map: "Criterio_grupoCriterioId_fkey")
  nota            Nota[]

  @@index([grupoCriterioId], map: "Criterio_grupoCriterioId_fkey")
}

model GrupoCriterio {
  id            BigInt      @id @default(autoincrement())
  nome          String?
  organizacaoId BigInt
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  concurso      Concurso[]
  criterio      Criterio[]
  organizacao   Organizacao @relation(fields: [organizacaoId], references: [id], map: "GrupoCriterio_organizacaoId_fkey")

  @@index([organizacaoId], map: "GrupoCriterio_organizacaoId_fkey")
}

model Inscricao {
  id               BigInt                     @id @default(autoincrement())
  concursoId       BigInt
  participanteId   BigInt
  status           InscricaoStatus            @default(CONFIRMADA)
  statusPagamento  InscricaoStatusPagamento   @default(ISENTO)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  concurso         Concurso                  @relation(fields: [concursoId], references: [id], map: "Inscricao_concursoId_fkey")
  participante     Participante              @relation(fields: [participanteId], references: [id], map: "Inscricao_participanteId_fkey")
  submissao        Submissao[]

  @@unique([concursoId, participanteId], map: "Inscricao_concursoId_participanteId_key")
  @@index([participanteId], map: "Inscricao_participanteId_fkey")
}

model Jurado {
  id         BigInt  @id @default(autoincrement())
  profissao  String?
  formacao   String?
  biografia  String?
  pessoaId   BigInt  @unique(map: "Jurado_pessoaId_key")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  banca      Banca[]
  pessoa     Pessoa  @relation(fields: [pessoaId], references: [id], map: "Jurado_pessoaId_fkey")
}

model Nota {
  id               BigInt            @id @default(autoincrement())
  justificativa    String?
  valor            Decimal           @db.Decimal(5, 2)
  analiseId        BigInt
  criterioId       BigInt
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analiseavaliacao AnaliseAvaliacao  @relation(fields: [analiseId], references: [id], map: "Nota_analiseId_fkey")
  criterio         Criterio          @relation(fields: [criterioId], references: [id], map: "Nota_criterioId_fkey")

  @@unique([analiseId, criterioId], map: "Nota_analiseId_criterioId_key")
  @@index([criterioId], map: "Nota_criterioId_fkey")
}

model Obra {
  id              BigInt        @id @default(autoincrement())
  titulo          String?
  tema            String?
  texto           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  participanteId  BigInt?
  participante    Participante? @relation(fields: [participanteId], references: [id], map: "Obra_participanteId_fkey")
  submissao       Submissao[]

  @@index([participanteId], map: "Obra_participanteId_fkey")
}

model Organizacao {
  id             BigInt          @id @default(autoincrement())
  nomeFantasia   String?
  razaoSocial    String?
  tipo           String?
  cep            BigInt?
  endereco       String?
  municipio      String?
  uf             String?         @db.Char(2)
  pessoaId       BigInt          @unique(map: "Organizacao_pessoaId_key")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  concurso       Concurso[]
  grupoCriterio  GrupoCriterio[]
  pessoa         Pessoa          @relation(fields: [pessoaId], references: [id], map: "Organizacao_pessoaId_fkey")
}

model Participante {
  id         BigInt      @id @default(autoincrement())
  pseudonimo String?
  pessoaId   BigInt      @unique(map: "Participante_pessoaId_key")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  inscricao  Inscricao[]
  obra       Obra[]
  pessoa     Pessoa      @relation(fields: [pessoaId], references: [id], map: "Participante_pessoaId_fkey")
}

model Pessoa {
  id           BigInt             @id @default(autoincrement())
  nome         String
  foto         String?
  documento    String?            @unique(map: "Pessoa_documento_key")
  tipoPessoa   PessoaTipoPessoa?
  tel          String?
  usuarioId    BigInt             @unique(map: "Pessoa_usuarioId_key")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  jurado       Jurado?
  organizacao  Organizacao?
  participante Participante?
  usuario      Usuario            @relation(fields: [usuarioId], references: [id], map: "Pessoa_usuarioId_fkey")
}

model Submissao {
  id               BigInt             @id @default(autoincrement())
  obraId           BigInt
  inscricaoId      BigInt
  status           SubmissaoStatus    @default(PENDENTE)
  notaFinal        Decimal            @db.Decimal(5, 2)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  analiseavaliacao AnaliseAvaliacao[]
  inscricao        Inscricao          @relation(fields: [inscricaoId], references: [id], map: "Submissao_inscricaoId_fkey")
  obra             Obra               @relation(fields: [obraId], references: [id], map: "Submissao_obraId_fkey")

  @@unique([obraId, inscricaoId], map: "Submissao_obraId_inscricaoId_key")
  @@index([inscricaoId], map: "Submissao_inscricaoId_fkey")
}

model Usuario {
  id        BigInt       @id @default(autoincrement())
  email     String       @unique(map: "Usuario_email_key")
  senha     String
  tipo      TipoUsuario
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  pessoa    Pessoa?
}

enum AnaliseAvaliacaoStatus {
  PENDENTE
  FINALIZADA
}

enum InscricaoStatus {
  PENDENTE
  CONFIRMADA
  CANCELADA
}

enum SubmissaoStatus {
  PENDENTE
  APROVADA
  DESCLASSIFICADA
}

enum TipoUsuario {
  ADMIN
  JURADO
  PARTICIPANTE
  ORGANIZACAO
}

enum InscricaoStatusPagamento {
  PENDENTE
  PAGO
  ISENTO
}

enum PessoaTipoPessoa {
  PF
  PJ
}